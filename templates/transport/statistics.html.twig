{% extends 'back.html.twig' %}

{% block title %}Transport Type Statistics{% endblock %}

{% block content %}
  <div class="container-fluid">
    <h1 class="mb-4">Transport Type Statistics</h1>

    <div class="d-flex justify-content-center">
  <div style="width: 400px; height: 400px;">
    <canvas id="transportPieChart"></canvas>
  </div>
</div>

  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const ctx = document.getElementById('transportPieChart').getContext('2d');
    const transportPieChart = new Chart(ctx, {
        type: 'pie',
        data: {
            labels: {{ labels|raw }},
            datasets: [{
                label: 'Number of Transports',
                data: {{ data|raw }},
                borderWidth: 1
            }]
        },
        options: {
            responsive: true
        }
    });
  </script>
{% endblock %}
