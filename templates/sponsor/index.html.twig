{% extends 'base-back.html.twig' %}

{% block title %}Sponsor{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Sponsors</h1>

        <!-- Formulaire de recherche -->
       
        <div class="header">
            <div class="header-content">
                <nav class="navbar navbar-expand">
                    <div class="collapse navbar-collapse justify-content-between">
                        <div class="header-left">
                            <div class="search_bar dropdown">
                                <span class="search_icon p-3 c-pointer" data-toggle="dropdown">
                                    <i class="mdi mdi-magnify"></i>
                                </span>
                                <div class="dropdown-menu p-0 m-0">
                                     <!-- search form -->
                                     <form method="get" action="{{ path('app_sponsor_index') }}" class="mb-4">
                                        <input class="form-control" name="search" type="search" placeholder="Rechercher un sponsor..." value="{{ searchTerm }}">
                                    </form>
                                </div>
                            </div>
                        </div>

                        
                    </div>
                </nav>
            </div>
        </div>

        <!-- Table des sponsors -->
        <div class="card">
            <div class="card-body">
                <table class="table table-striped table-bordered text-dark">
                    <thead>
                        <tr>
                            <th>Nom Sponsor</th>
                            <th>Email</th>
                            <th>Contribution</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for sponsor in sponsors %}
                        <tr>
                            <td>{{ sponsor.nomSponsor }}</td>
                            <td>{{ sponsor.emailSpon }}</td>
                            <td>{{ sponsor.contribution }} DT</td>
                            <td>
                                <a href="{{ path('app_sponsor_show', {'idsponsor': sponsor.idsponsor}) }}" class="btn btn-info btn-sm">Show</a>
                                <a href="{{ path('app_sponsor_edit', {'idsponsor': sponsor.idsponsor}) }}" class="btn btn-warning btn-sm">Edit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center">No records found</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <div class="mt-4">
            <nav>
                <ul class="pagination justify-content-center">
                    {% for i in 1..totalPages %}
                        <li class="page-item {% if i == currentPage %}active{% endif %}">
                            <a class="page-link"
                               href="{{ path('app_sponsor_index', {'page': i, 'search': searchTerm}) }}">
                                {{ i }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        </div>

        <!-- Bouton pour créer un nouveau sponsor -->
        <div class="mt-3">
            <a href="{{ path('app_sponsor_new') }}" class="btn btn-success">Create new</a>
        </div>
    </div>
{% endblock %}
