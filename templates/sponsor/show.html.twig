{% extends 'base-back.html.twig' %}

{% block title %}Sponsor{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Sponsor</h1>

        <!-- Détails du sponsor -->
        <div class="card">
            <div class="card-body">
                <table class="table table-striped">
                    <tbody class="text-dark">
                        
                        <tr>
                            <th>Nom Sponsor</th>
                            <td>{{ sponsor.nomSponsor }}</td>
                        </tr>
                        <tr>
                            <th>Email Sponsor</th>
                            <td>{{ sponsor.emailSpon }}</td>
                        </tr>
                        <tr>
                            <th>Contribution</th>
                            <td>{{ sponsor.contribution }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Actions (Back and Edit) -->
        <div class="mt-4">
            <a href="{{ path('app_sponsor_index') }}" class="btn btn-secondary">⬅ Back to list</a>
            <a href="{{ path('app_sponsor_edit', {'idsponsor': sponsor.idsponsor}) }}" class="btn btn-primary">✏️ Edit</a>
        </div>

        <!-- Formulaire de suppression -->
        <div class="mt-4">
            {{ include('sponsor/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
