{% extends 'front.html.twig' %}

{% block title %}Trajet List{% endblock %}

{% block body %}
<br><br><br><br><br>
<div class="container">
  <h1 class="mb-4">Trajet List</h1>

  <form method="get" class="mb-4 d-flex flex-wrap gap-3">
    <input type="text" name="departure" class="form-control w-auto" placeholder="Search by Departure" value="{{ departure }}">
    <input type="text" name="destination" class="form-control w-auto" placeholder="Search by Destination" value="{{ destination }}">
    <button type="submit" class="btn btn-primary">Search</button>
    <a href="{{ path('app_trajet_calendar') }}" class="btn btn-primary mb-3">
      📅 View Calendar
    </a>
  </form>

  <div class="row">
    {% for trajet in trajets %}
      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
          {% if trajet.transport and trajet.transport.image %}
            <img src="{{ asset('uploads/' ~ trajet.transport.image) }}"
                 class="card-img-top"
                 style="height: 200px; object-fit: contain;"
                 alt="Transport Image">
          {% endif %}

          <div class="card-body">
            
            
            <p class="card-text"><strong>Schedule:</strong>
              {% if trajet.schedule %}
                {{ trajet.schedule|date('d/m/Y') }}
              {% else %}
                -
              {% endif %}
            </p>
            <p class="card-text"><strong>Price:</strong> {{ trajet.price }} TND</p>
            <p class="card-text"><strong>Status:</strong> {{ trajet.statut ?? 'N/A' }}</p>

            {% if trajet %}
              <img src="{{ asset('QR/trajet_' ~ trajet.id ~ '.png') }}" class="img-fluid mt-2" alt="QR Code">
            {% endif %}
          </div>

          <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('app_trajet_show', {'id': trajet.id}) }}" class="btn btn-info btn-sm">Show</a>
            <a href="{{ path('app_trajet_edit', {'id': trajet.id}) }}" class="btn btn-warning btn-sm">Edit</a>
            <form method="post" action="{{ path('app_trajet_delete', {'id': trajet.id}) }}" onsubmit="return confirm('Are you sure?')" style="display:inline;">
              <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ trajet.id) }}">
              <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
          </div>
        </div>
      </div>
    {% else %}
      <div class="col-12 text-center">
        <div class="alert alert-warning">No records found</div>
      </div>
    {% endfor %}
  </div>

</div>
{% endblock %}
