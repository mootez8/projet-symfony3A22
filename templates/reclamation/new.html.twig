{% extends 'base-front.html.twig' %}

{% block title %}New Reclamation{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('front-office/css/style.css') }}">
    <style>
        /* Styles améliorés */
        body {
            font-family: 'Arial', sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 0;
        }

        h1 {
            color: #333;
            text-align: center;
            margin-top: 20px;
            font-size: 2rem;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-top: 30px;
        }

        .form-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .form-container a {
            text-align: center;
            text-decoration: none;
            color: #4CAF50;
            font-weight: bold;
            margin-top: 20px;
            font-size: 1rem;
        }

        .form-container a:hover {
            text-decoration: underline;
        }

        .back-btn {
            text-align: center;
            margin-top: 20px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container">
        <h1>Créer une nouvelle réclamation</h1>

        <div class="form-container">
            {{ include('reclamation/_form.html.twig') }}

           
        </div>
    </div>
{% endblock %}
