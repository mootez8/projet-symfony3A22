

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

    {# Affichage des champs avec validation #}
    <div class="form-group">
        {{ form_label(form.nom_utilisateur) }}
        {{ form_widget(form.nom_utilisateur) }}
        {% if form.nom_utilisateur.vars.errors|length > 0 %}
            <div class="text-danger">
                {{ form_errors(form.nom_utilisateur) }}
            </div>
        {% endif %}
    </div>

    <div class="form-group">
        {{ form_label(form.email) }}
        {{ form_widget(form.email) }}
        {% if form.email.vars.errors|length > 0 %}
            <div class="text-danger">
                {{ form_errors(form.email) }}
            </div>
        {% endif %}
    </div>

    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description) }}
        {% if form.description.vars.errors|length > 0 %}
            <div class="text-danger">
                {{ form_errors(form.description) }}
            </div>
        {% endif %}
    </div>

    {# Affichage du champ catégorie #}
    <div class="form-group">
        {{ form_label(form.categorie) }}
        {{ form_widget(form.categorie) }}
    </div>

 

{{ form_end(form) }}
