{% extends 'base-back.html.twig' %}

{% block title %}Reclamation{% endblock %}

{% block body %}
    <h1 style="text-align: center; margin-top: 200px;">Détails de la Réclamation</h1>

    <!-- Tableau stylisé centré -->
    <div style="display: flex; justify-content: center; margin-top: 40px;">
        <table class="table table-bordered table-sm" style="font-size: 18px; width: 70%; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); overflow: hidden;">
            <thead style="background-color: #f8f9fa; color: #343a40;">
                <tr>
                    <th colspan="2" style="text-align: center; padding: 15px; color: #000;">Informations sur la Réclamation</th>
                </tr>
            </thead>
            <tbody>
               
                <tr>
                    <th style="background-color: #f1f1f1; color: #000;">👤 Nom Utilisateur</th>
                    <td>{{ reclamation.nomUtilisateur }}</td>
                </tr>
                <tr>
                    <th style="background-color: #f1f1f1; color: #000;">📧 Email</th>
                    <td>{{ reclamation.email }}</td>
                </tr>
                <tr>
                    <th style="background-color: #f1f1f1; color: #000;">📝 Description</th>
                    <td>{{ reclamation.description }}</td>
                </tr>
                <tr>
                    <th style="background-color: #f1f1f1; color: #000;">📂 Catégorie</th>
                    <td>{{ reclamation.categorie }}</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Liens stylisés -->
    <div style="text-align: center; margin-top: 30px;">
        <a href="{{ path('app_reclamation_index') }}" style="margin-right: 20px; font-size: 18px; color: #007bff; text-decoration: none; font-weight: bold;">← Retour à la liste</a>
        <a href="{{ path('app_reclamation_edit', {'id_reclamation': reclamation.id_reclamation}) }}" style="margin-right: 20px; font-size: 18px; color: #28a745; text-decoration: none; font-weight: bold;">✏️ Modifier</a>
         <a href="{{ path('app_reclamation_translate', {'id_reclamation': reclamation.idReclamation}) }}" style="margin-right: 20px; font-size: 18px; color: #17a2b8; text-decoration: none; font-weight: bold;">
        🌍 Traduire en anglais
    </a>

        <div style="margin-top: 20px;">
            {{ include('reclamation/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
