{% extends 'base.html.twig' %}

{% block title %}Créer une nouvelle offre{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4 text-primary fw-bold">Créer une nouvelle offre</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                {{ form_start(form) }}

                    <div class="mb-3">
                        {{ form_label(form.prix_offre) }}
                        {{ form_widget(form.prix_offre, { 'attr': {'class': 'form-control'} }) }}
                        {{ form_errors(form.prix_offre) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.description_offre) }}
                        {{ form_widget(form.description_offre, { 'attr': {'class': 'form-control', 'rows': '5'} }) }}
                        {{ form_errors(form.description_offre) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.id_event) }}
                        {{ form_widget(form.id_event, { 'attr': {'class': 'form-control'} }) }}
                        {{ form_errors(form.id_event) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.nbr_placesDis) }}
                        {{ form_widget(form.nbr_placesDis, { 'attr': {'class': 'form-control'} }) }}
                        {{ form_errors(form.nbr_placesDis) }}
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-primary">Créer l'offre</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a href="{{ path('app_offre_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
        </div>
    </div>
{% endblock %}
