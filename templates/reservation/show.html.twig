{% extends 'base.html.twig' %}

{% block title %}Détails de la Réservation{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="text-primary fw-bold mb-4">Détails de la Réservation</h1>

        <div class="card shadow-sm rounded">
            <div class="card-body">
                <table class="table table-bordered table-striped">
                    <tbody>
                        <tr>
                            <th scope="row">ID Réservation</th>
                            <td>{{ reservation.id }}</td>
                        </tr>
                       
                        <tr>
                            <th scope="row">Date</th>
                            <td>{{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d H:i:s') : 'Non spécifiée' }}</td>
                        </tr>
                        <tr>
                            <th scope="row">Offre</th>
                            <td>{{ reservation.id }}</td>
                        </tr>
                        <tr>
                            <th scope="row">Places Réservées</th>
                            <td>{{ reservation.nbrPlaces }}</td>
                        </tr>
                        <tr>
                            <th scope="row">Montant Total</th>
                            <td>{{ reservation.prixTotal }} TND</td>
                        </tr>
                    </tbody>
                </table>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a href="{{ path('app_reservation_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Retour
                    </a>
                    <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" class="btn btn-warning">
                        <i class="bi bi-pencil-square"></i> Modifier
                    </a>
                    {{ include('reservation/_delete_form.html.twig', { id: reservation.id }) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
