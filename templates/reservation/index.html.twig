{% extends 'base.html.twig' %}

{% block title %}Liste des Réservations{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4 text-primary fw-bold">Liste des Réservations</h1>

        {# Flash messages #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <div class="card shadow-lg rounded">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Réservations</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID Réservation</th>
                                <th>Date Réservation</th>
                                <th>Offre</th>
                                <th>Nombre de Places</th>
                                <th>Montant Total</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for reservation in reservations %}
                                <tr>
                                    <td>{{ reservation.id }}</td>
                                    <td>{{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d H:i:s') : 'N/A' }}</td>
                                    <td>{{ reservation.offre.id }}</td>
                                    <td>{{ reservation.nbrPlaces }}</td>
                                    <td class="calculated-total" data-offer-id="{{ reservation.offre.id }}" data-seats="{{ reservation.nbrPlaces }}"></td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" 
                                               class="btn btn-info btn-sm" 
                                               title="Afficher">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" 
                                               class="btn btn-warning btn-sm" 
                                               title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <form method="post" 
                                                  action="{{ path('app_reservation_delete', {'id': reservation.id}) }}" 
                                                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette réservation?');"
                                                  class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                                <button class="btn btn-danger btn-sm" title="Supprimer">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted">Aucune réservation trouvée</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-end mt-3">
                    <a href="{{ path('app_reservation_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Créer une nouvelle réservation
                    </a>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-center mt-4">
            <a href="{{ path('app_offre_index') }}" class="btn btn-outline-primary">
                <i class="fas fa-tag"></i> Voir les offres
            </a>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const calculatedTotalCells = document.querySelectorAll('.calculated-total');

            calculatedTotalCells.forEach(cell => {
                const offerId = cell.dataset.offerId;
                const seats = parseInt(cell.dataset.seats);

                if (!isNaN(seats) && offerId) {
                    fetch(`/reservation/offer/details/${offerId}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data && !isNaN(data.prix_offre)) {
                                const total = data.prix_offre * seats;
                                cell.textContent = total.toFixed(2) + ' TND';
                            } else {
                                cell.textContent = 'N/A';
                            }
                        })
                        .catch(error => {
                            console.error('Error fetching offer details:', error);
                            cell.textContent = 'Error';
                        });
                } else {
                    cell.textContent = 'N/A';
                }
            });
        });
    </script>
{% endblock %}