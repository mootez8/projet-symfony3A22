{% extends 'base-back.html.twig' %}

{% block title %}Event{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Events</h1>


       
        <!-- Table des événements -->
        <div class="card">
         
                <!-- search form -->
                <form method="get" action="{{ path('app_event_indexBack') }}">
                   <input class="form-control" name="search" type="search" placeholder="Rechercher un événement..." value="{{ app.request.get('search') }}">
               </form>
           
            <div class="card-body">
                <table class="table table-striped table-bordered text-dark"> <!-- Ajout de text-dark ici -->
                    <thead>
                        <tr>
                          
                            <th>Nom de l'evenement</th>
                            <th>Description</th>
                            <th>Date de l'evenement</th>
                            <th>Nom de sponsor</th>
                            <th>Lieu</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for event in events %}
                        <tr>
                            
                            <td>{{ event.nomEv }}</td>
                            <td>{{ event.description }}</td>
                            <td>{{ event.dateEvent ? event.dateEvent|date('Y-m-d') : '' }}</td>
                            <td>{{ event.sponsor.nomSponsor }}</td>
                            <td>{{ event.lieu }}</td>
                            <td>
                                <a href="{{ path('app_event_show', {'idEvent': event.idEvent}) }}" class="btn btn-info btn-sm">Show</a>
                                <a href="{{ path('app_event_edit', {'idEvent': event.idEvent}) }}" class="btn btn-warning btn-sm">Edit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center">No records found</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                <div class="mt-4">
                    <nav>
                        <ul class="pagination justify-content-center">
                            {% for i in 1..totalPages %}
                                <li class="page-item {% if i == currentPage %}active{% endif %}">
                                    <a class="page-link"
                                       href="{{ path('app_event_indexBack', {'page': i, 'search': searchTerm}) }}">
                                        {{ i }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </nav>
                </div>
            </div>
        </div>

        <!-- Bouton pour créer un nouvel événement -->
        <div class="mt-3">
            <a href="{{ path('app_event_new') }}" class="btn btn-success">Create new</a>
        </div>
    </div>
{% endblock %}