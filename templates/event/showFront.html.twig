<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ event.nomEv }}</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    
    <style>
        #map-container {
            height: 400px;
            border-radius: 8px;
            border: 1px solid #ddd;
            margin: 20px 0;
            overflow: hidden;
        }
        #map {
            height: 100%;
            width: 100%;
        }
        .card {
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .weather-card {
            margin-bottom: 20px;
        }
        .weather-icon {
            width: 50px;
            height: 50px;
        }
        .weather-loading {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .spinner {
            width: 2rem;
            height: 2rem;
            margin-right: 10px;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container py-4">
        <h1 class="mb-3">{{ event.nomEv }}</h1>
        
        <div class="card mb-4">
            <div class="card-body">
                <table class="table">
                    <tbody class="text-dark">
                        <tr>
                            <th>Nom de l'événement</th>
                            <td>{{ event.nomEv }}</td>
                        </tr>
                        <tr>
                            <th>Description</th>
                            <td>{{ event.description }}</td>
                        </tr>
                        <tr>
                            <th>Date de l'événement</th>
                            <td>{{ event.dateEvent ? event.dateEvent|date('Y-m-d') : 'Non précisée' }}</td>
                        </tr>
                        <tr>
                            <th>Nom du sponsor</th>
                            <td>{{ event.sponsor.nomSponsor }}</td>
                        </tr>
                        <tr>
                            <th>Lieu</th>
                            <td>{{ event.lieu }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Section Météo améliorée -->
        <h2 class="h4 mb-3">Météo du lieu</h2>
        <div id="weather-container" class="weather-card card">
            <div class="card-body">
                <div id="weather-content">
                    <div class="weather-loading">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Chargement...</span>
                        </div>
                        <p class="mb-0">Chargement de la météo pour <strong>{{ event.lieu }}</strong>...</p>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="h4 mb-3">Localisation</h2>
        <div id="map-container">
            <div id="map"></div>
        </div>
        
        <div class="mt-3">
            <a href="{{ path('app_event_index') }}" class="btn btn-secondary">
                ← Retour à la liste
            </a>
        </div>
    </div>

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Configuration
            const lieu = "{{ event.lieu|e('js') }}";
            const defaultCoords = [36.8, 10.18]; // Coordonnées par défaut (Tunis)
            
            // Éléments UI
            const weatherContent = document.getElementById('weather-content');
            const mapContainer = document.getElementById('map-container');
            
            // 1. Initialisation de la carte avec vue par défaut
            const map = L.map('map').setView(defaultCoords, 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
            }).addTo(map);

            // 2. Géocodage du lieu
            geocodeLocation(lieu)
                .then(coords => {
                    // 3. Mise à jour de la carte
                    updateMap(coords, lieu);
                    
                    // 4. Récupération de la météo
                    return fetchWeather(coords.lat, coords.lon, lieu);
                })
                .catch(error => {
                    console.error("Erreur principale:", error);
                    showError(`Erreur: ${error.message}`);
                });

            // Fonctions principales
            function geocodeLocation(locationName) {
                return new Promise((resolve, reject) => {
                    fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(locationName)}&format=json&limit=1`)
                        .then(response => {
                            if (!response.ok) {
                                throw new Error(`Erreur réseau: ${response.status}`);
                            }
                            return response.json();
                        })
                        .then(data => {
                            if (data.length > 0) {
                                resolve({
                                    lat: parseFloat(data[0].lat),
                                    lon: parseFloat(data[0].lon)
                                });
                            } else {
                                throw new Error("Lieu non trouvé");
                            }
                        })
                        .catch(error => {
                            console.error("Erreur de géocodage:", error);
                            reject(new Error("Impossible de localiser ce lieu"));
                        });
                });
            }

            function updateMap(coords, locationName) {
                map.setView([coords.lat, coords.lon], 14);
                L.marker([coords.lat, coords.lon])
                    .addTo(map)
                    .bindPopup(`<b>${locationName}</b><br><small>Lieu de l'événement</small>`)
                    .openPopup();
            }

            async function fetchWeather(lat, lon, locationName) {
                const apiKey = "ta3ya w enti ta9beth";
                const url = `https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lon}&appid=${apiKey}&units=metric&lang=fr`;
                
                try {
                    const response = await fetch(url);
                    
                    if (!response.ok) {
                        const errorData = await response.json();
                        throw new Error(errorData.message || `Erreur ${response.status}`);
                    }
                    
                    const data = await response.json();
                    
                    if (data.cod !== 200) {
                        throw new Error(data.message || "Réponse inattendue de l'API");
                    }
                    
                    displayWeather(data, locationName);
                } catch (error) {
                    console.error("Erreur météo:", error);
                    throw new Error(`Impossible d'obtenir les données météo: ${error.message}`);
                }
            }

            function displayWeather(weatherData, locationName) {
                const weather = weatherData.weather[0];
                const main = weatherData.main;
                const wind = weatherData.wind;
                
                weatherContent.innerHTML = `
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3>${locationName}</h3>
                            <p class="display-4 mb-0">${Math.round(main.temp)}°C</p>
                            <p class="text-capitalize">${weather.description}</p>
                            <div class="weather-details">
                                <small class="d-block">Ressenti: ${Math.round(main.feels_like)}°C</small>
                                <small class="d-block">Humidité: ${main.humidity}%</small>
                                <small class="d-block">Vent: ${(wind.speed * 3.6).toFixed(1)} km/h</small>
                                <small class="d-block">Pression: ${main.pressure} hPa</small>
                            </div>
                        </div>
                        <div class="text-center">
                            <img src="https://openweathermap.org/img/wn/${weather.icon}@2x.png" 
                                 alt="${weather.description}" class="weather-icon mb-2">
                            <div class="temp-range">
                                <small>Max: ${Math.round(main.temp_max)}°C</small>
                                <small>Min: ${Math.round(main.temp_min)}°C</small>
                            </div>
                        </div>
                    </div>
                `;
            }

            function showError(message) {
                weatherContent.innerHTML = `
                    <div class="alert alert-danger d-flex justify-content-between align-items-center">
                        <div>${message}</div>
                        <button onclick="window.location.reload()" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-clockwise"></i> Réessayer
                        </button>
                    </div>
                `;
                
                // Afficher quand même la carte avec la vue par défaut
                mapContainer.innerHTML += `
                    <div class="alert alert-warning mt-3">
                        La carte montre une position par défaut
                    </div>
                `;
            }
        });
    </script>
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</body>
</html>