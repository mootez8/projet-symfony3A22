

{% extends 'base-back.html.twig' %}

{% block title %}New Event{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Create new Event</h1>

        <!-- Formulaire de création d'événement -->
        <div class="card">
            <div class="card-body">

                <style>
                    label {
                        font-size: 0.85rem;
                    }
                </style>

                {{ include('event/_form.html.twig') }}
            </div>
        </div>

        <!-- Lien vers la liste des événements -->
        <div class="mt-3">
            <a href="{{ path('app_event_indexBack') }}" class="btn btn-secondary">← Back to list</a>
        </div>
    </div>
{% endblock %}

