{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}My App{% endblock %}</title>
    <link rel="icon" href="{{ asset('favicon.ico') }}" />
    {% block stylesheets %}{% endblock %}
  </head>
  <body>
    {% block header %}{% endblock %}
    {% block body %}{% endblock %}
    {% block javascripts %}{% endblock %}
  </body>
</html>
