                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content Section -->
    <div class="main-content">
        <div class="hero-wrap js-fullheight" style="background-image: url('front-office/images/bg_1');" data-stellar-background-ratio="0.5">
            <div class="overlay"></div>
            <div class="container" style="padding: 10px; margin-top: 5%">
                <div class="container-fluid">
                    <div class="card">
                        {% block body %}
                        <!-- Votre contenu ici -->
                        {% endblock %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    

